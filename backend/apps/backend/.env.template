# ============================================================
# ORIN.SE — Backend Environment Variables
# Copy this file to .env and fill in all values.
# NEVER commit .env to git.
# ============================================================

# --- Database ---
DATABASE_URL=postgresql://medusa:CHANGE_ME@localhost:5432/medusa_db

# --- Secrets (generate with: openssl rand -base64 32) ---
JWT_SECRET=
COOKIE_SECRET=

# --- CORS ---
STORE_CORS=http://localhost:3000,https://orin.se
ADMIN_CORS=http://localhost:9000,https://admin.orin.se
AUTH_CORS=http://localhost:3000,http://localhost:9000,https://orin.se,https://admin.orin.se

# --- Cloudflare R2 ---
# Endpoint: https://<account-id>.r2.cloudflarestorage.com
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=medusa-uploads
# CDN domain — NOT the raw R2 endpoint
R2_PUBLIC_URL=https://cdn.orin.se

# --- Stripe ---
STRIPE_API_KEY=sk_test_
STRIPE_WEBHOOK_SECRET=whsec_
